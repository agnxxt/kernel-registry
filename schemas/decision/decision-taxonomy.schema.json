{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/decision/decision-taxonomy.schema.json",
  "title": "DecisionTaxonomy",
  "description": "Machine-readable controlled vocabulary for identity-bearing decision graph resources.",
  "type": "object",
  "required": [
    "schema_version",
    "namespace",
    "resource_types",
    "relationship_types",
    "acceptable_values"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "namespace": {
      "type": "string",
      "format": "uri"
    },
    "resource_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "relationship_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "acceptable_values": {
      "type": "object",
      "required": [
        "resource_status",
        "decision_status",
        "decision_verdict",
        "priority",
        "severity",
        "likelihood_band",
        "confidence_band",
        "risk_status",
        "constraint_status",
        "approval_status",
        "evidence_kind",
        "evaluation_metric",
        "outcome_status",
        "sensitivity_classification"
      ],
      "properties": {
        "resource_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "decision_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "decision_verdict": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "priority": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "severity": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "likelihood_band": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "confidence_band": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "risk_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "constraint_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "approval_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evidence_kind": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evaluation_metric": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "outcome_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "sensitivity_classification": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
