{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/context-envelope.schema.json",
  "title": "ContextEnvelope",
  "type": "object",
  "required": [
    "context_id",
    "schema_version",
    "identity",
    "execution",
    "observability",
    "temporal"
  ],
  "properties": {
    "context_id": {
      "type": "string",
      "minLength": 8
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "identity": {
      "type": "object",
      "required": [
        "tenant_id",
        "agent_id"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 2
        },
        "user_id": {
          "type": "string"
        },
        "agent_id": {
          "type": "string",
          "minLength": 2
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "auth_strength": {
          "type": "string"
        },
        "canonical_id": {
          "type": "string",
          "pattern": "^cid:[a-z0-9:_\\-]{8,}$"
        },
        "credential_refs": {
          "type": "array",
          "items": {
            "$ref": "./identity/verifiable-credential.schema.json"
          }
        },
        "wallets": {
          "type": "array",
          "items": {
            "$ref": "./identity/wallet.schema.json"
          }
        },
        "trust_score": {
          "$ref": "./identity/trust-score.schema.json"
        },
        "registry_record": {
          "$ref": "./identity/registry-record.schema.json"
        }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "properties": {
        "dataset_id": {
          "type": "string"
        },
        "data_fingerprint": {
          "type": "string"
        },
        "sensitivity": {
          "type": "string"
        },
        "residency": {
          "type": "string"
        },
        "lineage_ref": {
          "type": "string"
        },
        "freshness": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "chunking": {
      "type": "object",
      "properties": {
        "chunk_strategy": {
          "type": "string"
        },
        "chunk_version": {
          "type": "string"
        },
        "chunk_id": {
          "type": "string"
        },
        "chunk_span": {
          "type": "string"
        },
        "overlap_tokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "retrieval": {
      "type": "object",
      "properties": {
        "retrieval_profile": {
          "type": "string"
        },
        "top_k": {
          "type": "integer",
          "minimum": 0
        },
        "retrieved_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rerank_profile": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "inference": {
      "type": "object",
      "properties": {
        "model_profile": {
          "type": "string"
        },
        "prompt_hash": {
          "type": "string"
        },
        "temperature_milli": {
          "type": "integer",
          "minimum": 0
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "inference_budget_ms": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "properties": {
        "risk_profile_id": {
          "type": "string"
        },
        "guardrail_mode": {
          "type": "string"
        },
        "pending_decision_id": {
          "type": "string"
        },
        "quorum_state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "task_id",
        "run_id",
        "step_id"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 2
        },
        "run_id": {
          "type": "string",
          "minLength": 2
        },
        "step_id": {
          "type": "string",
          "minLength": 2
        },
        "branch_path": {
          "type": "string"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "state_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "observability": {
      "type": "object",
      "required": [
        "trace_id"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 8
        },
        "correlation_id": {
          "type": "string"
        },
        "audit_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "incident_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "temporal": {
      "type": "object",
      "required": [
        "timestamp"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "deadline_at": {
          "type": "string",
          "format": "date-time"
        },
        "sla_budget_ms": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "awareness": {
      "$ref": "./context-awareness.schema.json"
    },
    "semantic_extension": {
      "$ref": "../_semantic-extension.schema.json"
    }
  },
  "additionalProperties": false
}
