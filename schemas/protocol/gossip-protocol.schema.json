{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agnxxt/agent-kernel/schemas/protocol/gossip-protocol.schema.json",
  "title": "GossipProtocolPayload",
  "type": "object",
  "required": [
    "gossip_id",
    "timestamp",
    "subject_agent_id",
    "gossip_type",
    "payload"
  ],
  "properties": {
    "gossip_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "subject_agent_id": {
      "type": "string"
    },
    "gossip_type": {
      "type": "string",
      "enum": [
        "REPUTATION_SYNC",
        "BELIEF_SYNC",
        "CAPABILITY_UPDATE",
        "ROGUE_ALERT"
      ]
    },
    "payload": {
      "type": "object",
      "properties": {
        "trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "belief_node": {
          "type": "object"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "violation_details": {
          "type": "string"
        }
      }
    },
    "ttl": {
      "type": "integer",
      "description": "Time to live for the gossip message in hops",
      "minimum": 1
    },
    "signature": {
      "type": "string",
      "description": "Cryptographic signature of the gossiping agent"
    }
  },
  "additionalProperties": false
}
