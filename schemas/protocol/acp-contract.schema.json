{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agnxxt/agent-kernel/schemas/protocol/acp-contract.schema.json",
  "title": "AgentClientProtocolContract",
  "type": "object",
  "required": [
    "protocol_version",
    "session_id",
    "agent_id",
    "capabilities"
  ],
  "properties": {
    "protocol_version": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "transports": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "grpc",
          "http",
          "websocket"
        ]
      }
    },
    "auth_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "api_key",
          "oauth2",
          "mTLS",
          "jwt"
        ]
      }
    }
  },
  "additionalProperties": false
}
