{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/featurestore/feast-online-request.schema.json",
  "title": "FeastOnlineFeatureRequest",
  "type": "object",
  "required": ["request_id", "trace_id", "tenant_id", "project", "entity_name", "entity_id", "feature_view", "feature_names"],
  "properties": {
    "request_id": { "type": "string", "minLength": 8 },
    "trace_id": { "type": "string", "minLength": 8 },
    "tenant_id": { "type": "string", "minLength": 2 },
    "project": { "type": "string", "minLength": 2 },
    "entity_name": { "type": "string", "minLength": 2 },
    "entity_id": { "type": "string", "minLength": 1 },
    "feature_view": { "type": "string", "minLength": 2 },
    "feature_names": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "event_timestamp": { "type": "string", "format": "date-time" },
    "semantic_extension": { "$ref": "../_semantic-extension.schema.json" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
