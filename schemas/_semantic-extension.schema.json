{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/_semantic-extension.schema.json",
  "title": "UniversalSemanticExtension",
  "description": "Standardized block injected into Schema.org types to support advanced AI cognition, lineage, and audit trails.",
  "type": "object",
  "properties": {
    "schema_definition": {
      "type": "object",
      "description": "The specific internal schema applied if Schema.org lacks native precision.",
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "version": { "type": "string" },
        "fallback_schema_org_type": { "type": "string" }
      }
    },
    "versioning": {
      "type": "object",
      "properties": {
        "semantic_version": { "type": "string" },
        "previous_version": { "type": "string" },
        "iteration_hash": { "type": "string" }
      }
    },
    "taxonomy": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "path": { "type": "array", "items": { "type": "string" } }
      }
    },
    "vocabulary": {
      "type": "object",
      "properties": {
        "namespace": { "type": "string", "format": "uri" },
        "terms": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": { "type": "string" },
              "iri": { "type": "string", "format": "uri" },
              "definition": { "type": "string" }
            }
          }
        }
      }
    },
    "ontology": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "classes": { "type": "array", "items": { "type": "string" } },
        "relations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "attributes": {
      "type": "object",
      "description": "Custom key-value pairs representing cognitive state, triggers, or policies.",
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "description": "Data provenance and transformation history.",
      "properties": {
        "source_artifacts": { "type": "array", "items": { "type": "string" } },
        "derived_from": { "type": "string" },
        "transformation_logic": { "type": "string" }
      }
    },
    "audit_tracking": {
      "type": "object",
      "properties": {
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_by": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" },
        "change_reason": { "type": "string" },
        "cryptographic_signature": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
