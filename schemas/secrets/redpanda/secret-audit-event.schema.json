{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/secrets/redpanda/secret-audit-event.schema.json",
  "title": "SecretAuditEvent",
  "type": "object",
  "required": ["event_id", "occurred_at", "actor", "action", "decision", "secret_id", "tenant_id", "trace_id"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "action": { "type": "string", "enum": ["put", "get", "rotate", "revoke", "deny"] },
    "decision": { "type": "string", "enum": ["allow", "deny"] },
    "secret_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "reason": { "type": "string" },
    "provider": { "type": "string" },
    "scope": { "type": "string" },
    "scope_ref": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true },
    "semantic_extension": { "$ref": "../../_semantic-extension.schema.json" }
  },
  "additionalProperties": false
}
