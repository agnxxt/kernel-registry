{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/secrets/secret-object.schema.json",
  "title": "SecretObject",
  "type": "object",
  "required": ["secret_id", "tenant_id", "scope", "name", "provider", "key_ref", "status"],
  "properties": {
    "secret_id": { "type": "string", "minLength": 8 },
    "tenant_id": { "type": "string", "minLength": 2 },
    "scope": { "type": "string", "enum": ["global", "org", "project", "agent", "task"] },
    "scope_ref": { "type": "string" },
    "name": { "type": "string", "minLength": 2 },
    "provider": { "type": "string", "enum": ["vault", "aws_kms", "gcp_kms", "azure_key_vault", "k8s_secrets"] },
    "key_ref": { "type": "string", "minLength": 2 },
    "status": { "type": "string", "enum": ["active", "rotating", "revoked", "expired"] },
    "expires_at": { "type": "string", "format": "date-time" },
    "rotated_at": { "type": "string", "format": "date-time" },
    "tags": { "type": "object", "additionalProperties": { "type": "string" } },
    "semantic_extension": { "$ref": "../_semantic-extension.schema.json" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
