{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/runtime/schemaorg-cognitive-bridge.schema.json",
  "title": "SchemaOrgCognitiveBridge",
  "description": "Bridges Kernel Cognitive Artifacts with Schema.org Action types for interoperable discovery.",
  "type": "object",
  "required": ["@context", "@type", "kernel_artifact"],
  "properties": {
    "@context": {
      "type": "string",
      "const": "https://schema.org"
    },
    "@type": {
      "type": "string",
      "enum": [
        "AssessAction",
        "PlanAction",
        "ControlAction",
        "Intangible"
      ],
      "description": "Schema.org type that best represents the cognitive operation."
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "kernel_artifact": {
      "type": "object",
      "required": ["artifact_kind"],
      "properties": {
        "artifact_kind": {
          "type": "string",
          "enum": [
            "active_probe",
            "epistemic_trust",
            "predictive_control",
            "active_inference",
            "dual_process_theory",
            "cognitive_profile"
          ]
        },
        "mapping_logic": {
          "type": "string",
          "description": "Semantic bridge explanation (e.g., ActiveProbe maps to AssessAction)."
        }
      }
    },
    "actionStatus": {
      "type": "string",
      "enum": [
        "PotentialActionStatus",
        "ActiveActionStatus",
        "CompletedActionStatus",
        "FailedActionStatus"
      ]
    },
    "agent": {
      "type": "object",
      "description": "The Schema.org Person or Organization (Agent) performing the cognitive action."
    },
    "object": {
      "type": "object",
      "description": "The entity or info-source being assessed or controlled."
    },
    "result": {
      "type": "object",
      "description": "The result of the cognitive process (e.g., a belief update)."
    }
  },
  "additionalProperties": true
}
