{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agnxxt/kernel-registry/schemas/runtime/cognitive-profile.schema.json",
  "title": "CognitiveProfile",
  "description": "Defines the internal state that drives an agent's knowledge expansion and subjective world-view.",
  "type": "object",
  "required": ["personality", "objectives", "constraints"],
  "properties": {
    "personality": {
      "type": "object",
      "properties": {
        "curiosity_index": { 
          "type": "number", 
          "description": "Drive to discover new artifacts vs exploit known ones.",
          "minimum": 0, "maximum": 1 
        },
        "skepticism_level": { 
          "type": "number", 
          "description": "How much the agent trusts public info vs requiring direct probing.",
          "minimum": 0, "maximum": 1 
        },
        "social_orientation": { 
          "enum": ["autonomous", "collaborative", "competitive"],
          "description": "Preference for Gossip vs Stigmergy vs Direct Instruction."
        }
      }
    },
    "objectives": {
      "type": "object",
      "properties": {
        "short_term_goals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Immediate tactical tasks that narrow the focus horizon."
        },
        "long_term_goals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Strategic goals that drive long-horizon knowledge acquisition."
        }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "attention_span_tokens": { "type": "integer" },
        "epistemic_budget": { 
          "type": "number", 
          "description": "Resource limit for 'curiosity' driven discovery." 
        },
        "security_clearance": { "type": "string" }
      }
    },
    "horizon_expansion_strategy": {
      "type": "string",
      "enum": [
        "greedy_utility",
        "random_exploration",
        "relevance_weighted",
        "peer_driven"
      ],
      "default": "relevance_weighted"
    }
  },
  "additionalProperties": false
}
