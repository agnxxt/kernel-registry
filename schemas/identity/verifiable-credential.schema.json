{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/identity/verifiable-credential.schema.json",
  "title": "VerifiableCredentialRef",
  "type": "object",
  "required": [
    "vc_id",
    "vc_type",
    "issuer",
    "holder_canonical_id",
    "proof_type",
    "status",
    "issued_at",
    "credential_hash"
  ],
  "properties": {
    "vc_id": {
      "type": "string",
      "format": "uri"
    },
    "vc_type": {
      "type": "string",
      "minLength": 2
    },
    "issuer": {
      "type": "string",
      "minLength": 2
    },
    "holder_canonical_id": {
      "type": "string",
      "pattern": "^cid:[a-z0-9:_\\-]{8,}$"
    },
    "proof_type": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "suspended",
        "expired"
      ]
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "credential_hash": {
      "type": "string",
      "minLength": 16
    },
    "claims": {
      "type": "object",
      "additionalProperties": true
    },
    "semantic_extension": {
      "$ref": "../../_semantic-extension.schema.json"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
