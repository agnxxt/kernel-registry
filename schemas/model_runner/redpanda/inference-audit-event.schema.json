{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/model_runner/redpanda/inference-audit-event.schema.json",
  "title": "InferenceAuditEvent",
  "type": "object",
  "required": ["event_id", "occurred_at", "request_id", "tenant_id", "agent_id", "provider", "model", "status", "trace_id"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "request_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "task_id": { "type": "string" },
    "run_id": { "type": "string" },
    "step_id": { "type": "string" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "status": { "type": "string", "enum": ["queued", "running", "succeeded", "failed", "canceled", "timeout"] },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "error_code": { "type": "string" },
    "trace_id": { "type": "string" },
    "semantic_extension": { "$ref": "../../_semantic-extension.schema.json" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
