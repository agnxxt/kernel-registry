{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/actions/kernel-actions.schema.json",
  "title": "KernelActionRequest",
  "type": "object",
  "required": [
    "action_id",
    "tenant_id",
    "agent_id",
    "task_id",
    "run_id",
    "step_id",
    "trace_id",
    "type",
    "provider",
    "operation",
    "input",
    "requested_at"
  ],
  "properties": {
    "action_id": { "type": "string", "minLength": 8 },
    "tenant_id": { "type": "string", "minLength": 2 },
    "agent_id": { "type": "string", "minLength": 2 },
    "task_id": { "type": "string", "minLength": 2 },
    "run_id": { "type": "string", "minLength": 2 },
    "step_id": { "type": "string", "minLength": 2 },
    "trace_id": { "type": "string", "minLength": 8 },
    "type": {
      "type": "string",
      "enum": [
        "connect",
        "automate",
        "flow",
        "loop",
        "search",
        "message",
        "publish",
        "post",
        "travel_book",
        "schema_org"
      ]
    },
    "provider": { "type": "string" },
    "operation": { "type": "string" },
    "input": { "type": "object", "additionalProperties": true },
    "policy": { "type": "object", "additionalProperties": true },
    "requested_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "automate" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["n8n"] },
          "operation": { "enum": ["run_workflow", "trigger_webhook", "upsert_workflow"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "flow" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["langgraph"] },
          "operation": { "enum": ["start_flow", "resume_flow", "inspect_state"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "search" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["google"] },
          "operation": { "enum": ["web_search", "news_search", "image_search"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "message" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["whatsapp"] },
          "operation": { "enum": ["send_text", "send_template", "send_media"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "publish" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["wordpress", "ghost", "medium"] },
          "operation": { "enum": ["publish_article", "update_article", "delete_article"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "post" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["x", "linkedin", "facebook", "instagram"] },
          "operation": { "enum": ["create_post", "schedule_post", "delete_post"] }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "travel_book" } } },
      "then": {
        "properties": {
          "provider": { "enum": ["uber"] },
          "operation": { "enum": ["estimate_ride", "book_ride", "cancel_ride"] }
        }
      }
    }
  ],
  "additionalProperties": false
}
