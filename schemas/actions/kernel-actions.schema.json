{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agnxxt.com/schemas/actions/kernel-actions.schema.json",
  "title": "KernelActionRequest",
  "type": "object",
  "required": [
    "action_id",
    "canonical_id",
    "tenant_id",
    "agent_id",
    "task_id",
    "run_id",
    "step_id",
    "trace_id",
    "type",
    "action_scope",
    "provider",
    "operation",
    "input",
    "requested_at"
  ],
  "properties": {
    "action_id": {
      "type": "string",
      "minLength": 8
    },
    "tenant_id": {
      "type": "string",
      "minLength": 2
    },
    "agent_id": {
      "type": "string",
      "minLength": 2
    },
    "task_id": {
      "type": "string",
      "minLength": 2
    },
    "run_id": {
      "type": "string",
      "minLength": 2
    },
    "step_id": {
      "type": "string",
      "minLength": 2
    },
    "trace_id": {
      "type": "string",
      "minLength": 8
    },
    "type": {
      "type": "string",
      "enum": [
        "connect",
        "automate",
        "flow",
        "loop",
        "search",
        "message",
        "publish",
        "post",
        "travel_book",
        "schema_org"
      ]
    },
    "provider": {
      "type": "string"
    },
    "operation": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "action_scope": {
      "type": "string",
      "enum": [
        "global",
        "org",
        "country",
        "local",
        "product",
        "project",
        "group",
        "individual"
      ]
    },
    "scope_ref": {
      "type": "object",
      "properties": {
        "org_id": {
          "type": "string"
        },
        "country_code": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "locality": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "group_id": {
          "type": "string"
        },
        "individual_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "canonical_id": {
      "type": "string",
      "pattern": "^cid:[a-z0-9:_\\-]{8,}$"
    },
    "verifiable_credentials": {
      "type": "array",
      "items": {
        "$ref": "../identity/verifiable-credential.schema.json"
      }
    },
    "semantic_extension": {
      "$ref": "../../_semantic-extension.schema.json"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "adapter_hints": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "automate"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "n8n"
            ]
          },
          "operation": {
            "enum": [
              "run_workflow",
              "trigger_webhook",
              "upsert_workflow"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "flow"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "langgraph"
            ]
          },
          "operation": {
            "enum": [
              "start_flow",
              "resume_flow",
              "inspect_state"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "search"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "google"
            ]
          },
          "operation": {
            "enum": [
              "web_search",
              "news_search",
              "image_search"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "message"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "whatsapp"
            ]
          },
          "operation": {
            "enum": [
              "send_text",
              "send_template",
              "send_media"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "publish"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "wordpress",
              "ghost",
              "medium"
            ]
          },
          "operation": {
            "enum": [
              "publish_article",
              "update_article",
              "delete_article"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "post"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "x",
              "linkedin",
              "facebook",
              "instagram"
            ]
          },
          "operation": {
            "enum": [
              "create_post",
              "schedule_post",
              "delete_post"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "travel_book"
          }
        }
      },
      "then": {
        "properties": {
          "provider": {
            "enum": [
              "uber"
            ]
          },
          "operation": {
            "enum": [
              "estimate_ride",
              "book_ride",
              "cancel_ride"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "org"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "org_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "country"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "country_code"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "local"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "locality"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "product"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "product_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "project"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "project_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "group"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "group_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action_scope": {
            "const": "individual"
          }
        }
      },
      "then": {
        "properties": {
          "scope_ref": {
            "required": [
              "individual_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "connect"
          },
          "provider": {
            "const": "git"
          }
        }
      },
      "then": {
        "properties": {
          "operation": {
            "enum": [
              "clone_repo",
              "fetch_repo",
              "open_pr",
              "list_branches",
              "read_file"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "automate"
          },
          "provider": {
            "const": "docker"
          }
        }
      },
      "then": {
        "properties": {
          "operation": {
            "enum": [
              "build_image",
              "run_container",
              "compose_up",
              "compose_down",
              "push_image",
              "pull_image"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "connect"
          },
          "provider": {
            "const": "caddy"
          }
        }
      },
      "then": {
        "properties": {
          "operation": {
            "enum": [
              "upsert_site",
              "reload_config",
              "add_reverse_proxy",
              "remove_site",
              "get_cert_status"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
