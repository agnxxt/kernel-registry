{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/agnxxt/agent-kernel/schemas/policy/openfga-tuple-write.schema.json",
  "title": "OpenFgaTupleWrite",
  "type": "object",
  "required": [
    "store_id",
    "authorization_model_id",
    "writes"
  ],
  "properties": {
    "store_id": {
      "type": "string"
    },
    "authorization_model_id": {
      "type": "string"
    },
    "writes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "user",
          "relation",
          "object"
        ],
        "properties": {
          "user": {
            "type": "string"
          },
          "relation": {
            "type": "string"
          },
          "object": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
